sequenceDiagram
    box Line Card — one NPU
        participant RTO as RouteOrch
        participant NO as NeighOrch
    end
    box Route Processor
        participant APP as APPL_DB
        participant NM as nbrmgrd
        participant K as Kernel
        participant NS as neighsyncd
    end

    RTO->>NO: 1. NH resolved?
    NO->>APP: 2. NEIGH_RESOLVE_TABLE (if unresolved)
    APP->>NM: 3. consume resolve
    NM->>K: 4. resolve NH
    K->>NS: 5. NH resolved (ARP/ND)
    NS->>APP: 6. update NEIGH_TABLE
