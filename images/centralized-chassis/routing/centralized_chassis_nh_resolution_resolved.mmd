    box Route Processor
        participant APP as APPL_DB
        participant CADB as CHASSIS_APP_DB
    end
    box Line Card — originating NPU
        participant NO as NeighOrch
        participant ADB as ASIC_DB
        participant RTO as RouteOrch
    end
    box Remote line card — other NPU
        participant RNO as Remote NeighOrch
    end

    APP->>NO: 7. NEIGH_TABLE
    NO->>ADB: 8. SAI_OBJECT_TYPE_NEIGHBOR_ENTRY
    NO->>ADB: 9. SAI_OBJECT_TYPE_NEXT_HOP
    RTO->>ADB: 10. complete route install
    NO->>CADB: SYSTEM_NEIGH (VOQ)
    CADB->>RNO: remote orch sync
    Note over NO,RNO: Centralized chassis: skip STATE_SYSTEM_NEIGH_TABLE
