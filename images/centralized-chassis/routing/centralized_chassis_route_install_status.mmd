sequenceDiagram
    box Line Card — one NPU
        participant HW as ASIC
        participant RO as RouteOrch
    end
    box Route Processor
        participant AST as APPL_STATE_DB
        participant FPM as fpmsyncd
        participant CP as BGP / Zebra
    end

    HW->>RO: 7. install status
    RO->>AST: 8. ROUTE status (last ASIC ACK)
    AST->>FPM: 9. consume status
    FPM->>CP: 10. RTM_NEWROUTE / RTM_F_OFFLOAD (FPM)
    CP->>CP: 11. advertise/withdraw
